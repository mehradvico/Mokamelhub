@using Application.Common.Dto.Result
@using Application.Common.Helpers
@using Application.Common.Enumerable
@using Application.Services.Order.ProductOrderSrv.Dto
@model BaseResultDto<PaymentDto>

@{
    Layout = null;
    ViewData["Title"] = "نتیجه پرداخت | مکمل هاب";
    var p = Model?.Data;
    var isSuccess = Model?.IsSuccess == true;
    var returnUrl = TempData["ReturnToSiteUrl"]?.ToString() ?? AppSettingsHelper.BaseUrl;
    var orderId = p?.ProductOrderId;
    var refNumber = p?.RefNumber;
    var amount = p?.Amount;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>

    <style>
        @@font -face {
            font-family: "YekanBakh";
            src: url("/Assets/Payment/fonts/YEKAN BAKH.TTF") format("truetype");
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: "YekanBakh", Tahoma, sans-serif;
        }

        body {
            background-color: #d1d1d1;
            background-image: url('/Assets/Payment/images/bg pic.png');
            background-repeat: no-repeat;
            background-position: left center;
            background-size: 55vw;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            direction: rtl;
        }

        @@Media (max-width: 768px) {
        body {
                background-size: 130vw;
                background-position: -20vw center;
            }
        }

        .payment-card {
            background-color: #ffffff;
            width: 100%;
            max-width: 420px;
            margin: 20px;
            border-radius: 24px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
            padding: 40px 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 10;
        }

        .brand-logo {
            height: 40px;
            margin-bottom: 30px;
            object-fit: contain;
        }

        .status-icon {
            width: 120px;
            height: 120px;
            margin-bottom: 25px;
            object-fit: contain;
        }

        .status-text {
            font-size: 20px;
            font-weight: 900;
            color: #000000;
            margin-bottom: 40px;
            text-align: center;
        }

        .info-list {
            width: 100%;
            margin-bottom: 30px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
        }

        .info-label {
            color: #000000;
            font-weight: 900;
        }

        .info-value {
            color: #555555;
            font-weight: bold;
            direction: ltr; /* برای نمایش درست اعداد */
        }

        /* دکمه بازگشت به سایت */
        .btn-return {
            display: block;
            width: 100%;
            padding: 14px;
            text-align: center;
            background-color: transparent;
            color: #000000;
            text-decoration: none;
            font-size: 16px;
            font-weight: 900;
            border: 2px solid #000000;
            border-radius: 12px;
            transition: all 0.2s ease-in-out;
            cursor: pointer;
        }

            .btn-return:hover {
                background-color: #000000;
                color: #ffffff;
            }
    </style>
</head>
<body>

    <div class="payment-card">
        <img class="brand-logo" src="/Assets/Payment/images/logo.png" alt="MOKAMELHUB" />

        @if (isSuccess)
        {
            <img class="status-icon" src="/Assets/Payment/images/success.png" alt="موفق" />
        }
        else
        {
            <img class="status-icon" src="/Assets/Payment/images/false.png" alt="ناموفق" />
        }

        <div class="status-text">
            @if (isSuccess)
            {
                <span>پرداخت شما با موفقیت انجام شد</span>
            }
            else
            {
                <span>پرداخت شما ناموفق بود!</span>
            }
        </div>

        @if (p != null)
        {
            <div class="info-list">
                @if (p.Type?.Label == PaymentTypeEnum.PaymentType_ProductOrder.ToString())
                {
                    @if (!string.IsNullOrWhiteSpace(orderId))
                    {
                        <div class="info-item">
                            <span class="info-label">شماره سفارش:</span>
                            <span class="info-value">@orderId</span>
                        </div>
                    }
                }
                else if (p.Type?.Label == PaymentTypeEnum.PaymentType_Wallet.ToString()
                && p.CallBackTypeLabel == PaymentCallbackTypeEnum.ProductOrder.ToString())
                {
                    @if (!string.IsNullOrWhiteSpace(p.CallBackId))
                    {
                        <div class="info-item">
                            <span class="info-label">شماره سفارش:</span>
                            <span class="info-value">@p.CallBackId</span>
                        </div>
                    }
                }

                @if (!string.IsNullOrWhiteSpace(refNumber))
                {
                    <div class="info-item">
                        <span class="info-label">شماره پیگیری:</span>
                        <span class="info-value">@refNumber</span>
                    </div>
                }

                @if (amount.HasValue)
                {
                    <div class="info-item">
                        <span class="info-label">@(isSuccess ? "مبلغ پرداختی:" : "مبلغ سفارش:")</span>
                        <span class="info-value">@amount.Value.ToString("n0") تومان</span>
                    </div>
                }
            </div>
        }

        <a class="btn-return" href="@returnUrl">بازگشت به سایت</a>
    </div>

</body>
</html>